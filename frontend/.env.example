# Production (GitHub Pages) — set as GitHub Actions secret VITE_API_URL
VITE_API_URL=https://robodocs-api.onrender.com

# Local dev: leave VITE_API_URL unset (Vite proxies /api → localhost:8000)
# VITE_API_URL=

# GitHub Pages base path (repo name). Local dev uses /
# VITE_BASE_PATH=/robotics-manual-rag/
